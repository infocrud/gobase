{
  "name": "@gobase/sdk",
  "version": "0.1.0",
  "description": "GoBase JavaScript/TypeScript client SDK",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": ["gobase", "baas", "supabase", "sdk"],
  "license": "MIT"
}
