# ─── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=gobase
DB_PASSWORD=gobase_secret
DB_NAME=gobase
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── MinIO (S3-compatible storage) ──────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=gobase-storage

# ─── JWT ─────────────────────────────────────────────
# IMPORTANT: Change this in production! Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ─── OAuth2: Google ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8001/auth/oauth/google/callback

# ─── OAuth2: GitHub ──────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8001/auth/oauth/github/callback

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1m

# ─── Realtime ────────────────────────────────────────
REALTIME_POLL_INTERVAL=1s

# ─── Signed URLs ─────────────────────────────────────
SIGNED_URL_EXPIRY=1h

# ─── Service Ports ───────────────────────────────────
GATEWAY_PORT=8000
AUTH_PORT=8001
REST_PORT=8002
REALTIME_PORT=8003
STORAGE_PORT=8004
FUNCTIONS_PORT=8005

# ─── Service URLs (override for Docker/K8s) ─────────
# Leave empty to auto-derive from localhost + port
# AUTH_URL=http://auth:8001
# REST_URL=http://rest:8002
# REALTIME_URL=http://realtime:8003
# STORAGE_URL=http://storage:8004
# FUNCTIONS_URL=http://functions:8005

# ─── CORS ────────────────────────────────────────────
# Comma-separated origins. Use '*' for development only.
# In production: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=*

# ─── SMTP (Email) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gobase.dev
SMTP_ENABLED=false

# ─── Environment ─────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug
